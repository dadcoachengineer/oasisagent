# OasisAgent Environment Variables
# Copy this file to .env and fill in your values.
#
# docker-compose.yml passes these to the container. The config.yaml baked
# into the image uses ${VAR} interpolation to read them at startup.
#
# Required = agent will not start without it
# Optional = has a sensible default, override if needed
#
# Docker Swarm / Portainer: set these in your orchestrator's env var UI
# instead of using this file. The agent also reads *_FILE env vars and
# populates the corresponding env vars from file contents (standard Docker
# secret pattern).

# --- Home Assistant (required) ---
# Long-lived access token from HA (Profile → Security → Long-Lived Access Tokens)
HA_TOKEN=your_ha_long_lived_access_token
# HA_URL=http://localhost:8123
# HA_WS_URL=ws://localhost:8123/api/websocket

# --- MQTT Broker (required) ---
# MQTT_BROKER=mqtt://localhost:1883
MQTT_USER=oasisagent
MQTT_PASS=your_mqtt_password

# --- LLM: T1 Triage (optional — defaults work for local Ollama) ---
# For cloud-hosted triage (e.g., OpenRouter), set all three:
# TRIAGE_LLM_BASE_URL=https://openrouter.ai/api/v1
# TRIAGE_LLM_MODEL=meta-llama/llama-3.1-8b-instruct
# TRIAGE_LLM_API_KEY=your_openrouter_key
# TRIAGE_LLM_TIMEOUT=15

# --- LLM: T2 Reasoning (required) ---
# API key for your cloud LLM provider (Anthropic, OpenAI, OpenRouter, etc.)
REASONING_LLM_API_KEY=your_llm_api_key
# REASONING_LLM_BASE_URL=https://api.anthropic.com
# REASONING_LLM_MODEL=claude-sonnet-4-5-20250929

# --- InfluxDB v2 (required) ---
# API token with write access to your OasisAgent bucket.
# If using the bundled InfluxDB (--profile monitoring), this token is also
# used as DOCKER_INFLUXDB_INIT_ADMIN_TOKEN — zero post-boot configuration.
INFLUXDB_TOKEN=your_influxdb_token
# INFLUX_URL=http://localhost:8086
# INFLUX_ORG=myorg
# INFLUX_BUCKET=oasisagent

# --- Safety ---
# DRY_RUN=true

# --- Email SMTP (optional — only if notifications.email.enabled) ---
# SMTP_USER=
# SMTP_PASS=

# --- InfluxDB Init (optional — only used by docker compose --profile monitoring) ---
# These configure the bundled InfluxDB container on first run.
# INFLUXDB_INIT_USERNAME=admin
# INFLUXDB_INIT_PASSWORD=changeme
# INFLUXDB_INIT_ORG=myorg
# INFLUXDB_INIT_BUCKET=oasisagent
