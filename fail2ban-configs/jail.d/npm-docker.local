# ─── Vaultwarden ─────────────────────────────────────────────────────────────
# Auth failures from Vaultwarden LXC (CT 108) via NFS pipeline

[vaultwarden]
enabled   = true
filter    = vaultwarden
action    = cloudflare-apiv4
            sendmail-whois[sender="%(sender)s", dest="%(destemail)s"]
maxretry  = 3
findtime  = 900
bantime   = 3600
logpath   = /log/bitwarden/vaultwarden.log

# ─── Home Assistant ──────────────────────────────────────────────────────────
# Auth failures from HAOS via CIFS Samba share

[homeassistant]
enabled   = true
filter    = homeassistant
action    = cloudflare-apiv4
            sendmail-whois[sender="%(sender)s", dest="%(destemail)s"]
maxretry  = 5
findtime  = 300
bantime   = 3600
logpath   = /log/homeassistant/home-assistant.log
