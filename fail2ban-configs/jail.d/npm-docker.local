# Fail2Ban jail configuration for Oasis home lab
# Last updated: 2026-03-15
#
# Active jails:
#   - npm-docker: Protects all NPM-proxied services via Cloudflare edge banning
#
# Disabled jails (TODO — need logging fixes first):
#   - bitwarden: Vaultwarden auth log format doesn't match old Bitwarden filter
#   - homeassistant: Log file missing / path broken

[DEFAULT]
# Ban escalation: starts at 10min, multiplies up on repeat offenders
# 10m → 50m → 5h → 10h → 2d → 5d → 10d → 20d
bantime.increment = true
bantime.multipliers = 1 5 30 60 300 720 1440 2880

# Cloudflare tunnel IPs + local ranges — never ban these
ignoreip = 127.0.0.1/8
            192.168.0.0/16
            172.16.0.0/12
            10.0.0.0/8

# Email notification defaults
destemail = jason@shearer.live
sender    = fail2ban@shearer.live

# ─── NPM Jail ─────────────────────────────────────────────────────────────────

[npm-docker]
enabled  = true
filter   = npm-docker
action   = cloudflare-apiv4
           sendmail-whois[sender="%(sender)s", dest="%(destemail)s"]

# 15 hits in 60 seconds → 10 minute initial ban (then escalates)
maxretry  = 15
findtime  = 60
bantime   = 600

# NPM access logs — all proxy hosts
# Original hosts (1-19)
logpath  = /log/npm/default-host_access.log
           /log/npm/proxy-host-1_access.log
           /log/npm/proxy-host-2_access.log
           /log/npm/proxy-host-3_access.log
           /log/npm/proxy-host-4_access.log
